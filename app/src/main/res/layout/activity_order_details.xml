<?xml version="1.0" encoding="utf-8"?>
<!-- activity_order_details.xml -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/screen_background">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/polar_blue"
        android:paddingStart="8dp"
        android:paddingEnd="16dp"
        android:elevation="4dp">

        <!-- Back navigation Button -->
        <Button
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="‹"
            android:textSize="28sp"
            android:textColor="@color/polar_white"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="0dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Order Details"
            android:textColor="@color/polar_white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginStart="4dp" />

        <!-- Status Badge in Toolbar -->
        <TextView
            android:id="@+id/tvToolbarStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PENDING"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/polar_white"
            android:background="@drawable/badge_pending_white"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp" />
    </LinearLayout>

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Store Info Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@color/card_background">

                    <!-- Blue Header Bar -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="@color/polar_blue"
                        android:padding="16dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🏪"
                            android:textSize="24sp"
                            android:layout_marginEnd="12dp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvStoreName"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Sandy's Cafe"
                                android:textColor="@color/polar_white"
                                android:textSize="20sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvStoreId"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Order #001"
                                android:textColor="#B3FFFFFF"
                                android:textSize="13sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Address Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📍"
                            android:textSize="18sp"
                            android:layout_marginEnd="12dp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="DELIVERY ADDRESS"
                                android:textColor="@color/text_secondary"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.08" />

                            <TextView
                                android:id="@+id/tvAddress"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="12 Baker Street, Lagos"
                                android:textColor="@color/text_primary"
                                android:textSize="15sp" />
                        </LinearLayout>
                    </LinearLayout>


                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="16dp"
                        android:layout_marginEnd="16dp"
                        android:background="@color/divider" />

                    <!-- Delivery Notes Row -->
                    <LinearLayout
                        android:id="@+id/layoutNotes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⚠️"
                            android:textSize="18sp"
                            android:layout_marginEnd="12dp" />

                        <TextView
                            android:id="@+id/tvNotes"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textColor="@color/status_pending"
                            android:textSize="14sp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Order Items Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@color/card_background">

                    <!-- Items Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🧊"
                            android:textSize="20sp"
                            android:layout_marginEnd="10dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="ORDER ITEMS"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1" />

                        <TextView
                            android:id="@+id/tvTotalItems"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 tubs"
                            android:textColor="@color/polar_blue"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="16dp"
                        android:layout_marginEnd="16dp"
                        android:background="@color/divider" />

                    <!-- Dynamic Items Container -->
                    <LinearLayout
                        android:id="@+id/layoutItemsContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="8dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Failed Reason Input (hidden by default) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardFailedReason"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@color/status_failed_bg"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Reason for Failed Delivery"
                        android:textColor="@color/status_failed"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="10dp" />

                    <EditText
                        android:id="@+id/etFailedReason"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="e.g. Store Closed, No One Available..."
                        android:inputType="textMultiLine"
                        android:minLines="2"
                        android:maxLines="4"
                        android:padding="12dp"
                        android:background="@drawable/edittext_background"
                        android:textSize="15sp" />

                    <Button
                        android:id="@+id/btnConfirmFailed"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="CONFIRM FAILED DELIVERY"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/polar_white"
                        android:background="@drawable/btn_failed"
                        android:layout_marginTop="12dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Action Buttons -->
    <LinearLayout
        android:id="@+id/layoutActionButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/polar_white"
        android:padding="16dp"
        android:elevation="8dp">

        <!-- Mark as Delivered -->
        <Button
            android:id="@+id/btnMarkDelivered"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="@string/btn_mark_delivered"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/polar_white"
            android:background="@drawable/btn_delivered"
            android:layout_marginBottom="10dp" />

        <!-- Mark as Failed -->
        <Button
            android:id="@+id/btnMarkFailed"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="@string/btn_mark_failed"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/status_failed"
            android:background="@drawable/btn_failed_outline" />

    </LinearLayout>

    <!-- Already Updated Message -->
    <LinearLayout
        android:id="@+id/layoutAlreadyUpdated"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@color/polar_white"
        android:padding="20dp"
        android:elevation="8dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvStatusMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✓ This delivery has been marked as DELIVERED"
            android:textColor="@color/status_delivered"
            android:textSize="15sp"
            android:textStyle="bold"
            android:gravity="center" />
    </LinearLayout>

</LinearLayout>
