<?xml version="1.0" encoding="utf-8"?>
<!-- activity_login.xml -->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/polar_blue"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:minHeight="600dp">

        <!-- Logo Icon Area -->
        <LinearLayout
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/circle_white"
            android:layout_marginBottom="24dp">

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/mylogo"
                android:gravity="center" />

        </LinearLayout>

        <!-- Application name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/login_title"
            android:textColor="@color/polar_white"
            android:textSize="28sp"
            android:textStyle="bold"
            android:gravity="center"
            android:lineSpacingMultiplier="1.1"
            android:layout_marginBottom="8dp" />

        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Driver Portal"
            android:textColor="#B3FFFFFF"
            android:textSize="16sp"
            android:layout_marginBottom="48dp" />

        <!-- Login Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Driver ID Label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Driver ID"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="6dp" />

                <!-- Driver ID Field -->
                <EditText
                    android:id="@+id/etDriverId"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:hint="@string/driver_id_hint"
                    android:inputType="text"
                    android:textSize="16sp"
                    android:padding="16dp"
                    android:background="@drawable/edittext_background"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:imeOptions="actionNext"
                    android:maxLines="1"
                    android:layout_marginBottom="20dp" />

                <!-- Password Label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Password"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="6dp" />

                <!-- Password Field -->
                <EditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:hint="@string/password_hint"
                    android:inputType="textPassword"
                    android:textSize="16sp"
                    android:padding="16dp"
                    android:background="@drawable/edittext_background"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:imeOptions="actionDone"
                    android:layout_marginBottom="8dp" />

                <!-- Error Message -->
                <TextView
                    android:id="@+id/tvErrorMsg"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/invalid_credentials"
                    android:textColor="@color/status_failed"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:padding="8dp"
                    android:visibility="gone" />

                <!-- Login Button -->
                <Button
                    android:id="@+id/btnLogin"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:text="@string/btn_login"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/polar_white"
                    android:background="@drawable/btn_primary"
                    android:layout_marginTop="8dp"
                    android:letterSpacing="0.1" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Hint Text -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Use: DRIVER01 / password123"
            android:textColor="#80FFFFFF"
            android:textSize="13sp"
            android:gravity="center" />

    </LinearLayout>
</ScrollView>
